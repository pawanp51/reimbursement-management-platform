// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model
model User {
  id        String  @id @default(cuid())
  email     String  @unique
  password  String
  firstName String?
  lastName  String?
  role      Role    @default(EMPLOYEE)
  country   String?
  // Manager-Employee relationship (self-relation)
  managerId String? // Foreign key to manager
  manager   User?   @relation("ManagerToEmployee", fields: [managerId], references: [id], onDelete: SetNull)
  employees User[]  @relation("ManagerToEmployee")

  // Approval Rules
  approvalRules   ApprovalRule[]
  approverInRules ApprovalRuleApprover[]

  // Transactions
  transactions         Transaction[]
  transactionApprovals TransactionApproval[]

  // Relations
  otps OTP[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([managerId])
}

// OTP model for password reset
model OTP {
  id        String   @id @default(cuid())
  code      String
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
}

// Approval Rule model
model ApprovalRule {
  id                        String  @id @default(cuid())
  description               String
  isManagerApprover         Boolean @default(false)
  isApproversSequence       Boolean @default(false) // If true, approvers must approve in order
  minimalApprovalPercentage Int     @default(50) // Percentage of approvers needed

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Approvers list
  approvers ApprovalRuleApprover[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Junction table for Approval Rule Approvers (many-to-many)
model ApprovalRuleApprover {
  id             String @id @default(cuid())
  approvalRuleId String
  approverId     String
  sequenceOrder  Int? // Order if isApproversSequence is true

  // Relations
  approvalRule ApprovalRule @relation(fields: [approvalRuleId], references: [id], onDelete: Cascade)
  approver     User         @relation(fields: [approverId], references: [id], onDelete: Cascade)

  @@unique([approvalRuleId, approverId])
  @@index([approvalRuleId])
  @@index([approverId])
}

// Transaction/Reimbursement Request model
model Transaction {
  id          String            @id @default(cuid())
  description String
  expenseDate DateTime
  category    String
  paidBy      String // Employee, Corporate Card, etc.
  currency    String            @default("USD")
  totalAmount Float
  remarks     String?
  status      TransactionStatus @default(DRAFT)

  // Approval fields (populated after approval)
  approvedBy   String?
  approvalDate DateTime?

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Attachments
  attachments Attachment[]

  // Approvals tracking
  approvals TransactionApproval[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// Attachment model for storing file metadata
model Attachment {
  id       String @id @default(cuid())
  fileName String
  filePath String // Local file path
  fileType String // MIME type
  fileSize Int // Size in bytes

  // OCR extracted fields
  ocrData Json? // Extracted text/data from OCR

  // Relations
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
}

// Transaction Approval tracking model
model TransactionApproval {
  id           String         @id @default(cuid())
  status       ApprovalStatus @default(PENDING)
  approvalDate DateTime?
  comments     String?
  sequenceOrder Int?           // Order if isApproversSequence is true

  // Relations
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  approverId String
  approver   User   @relation(fields: [approverId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([transactionId, approverId])
  @@index([transactionId])
  @@index([approverId])
  @@index([status])
}

// Enums
enum Role {
  EMPLOYEE
  MANAGER
  CTO
  DIRECTOR
  ADMIN
}

enum TransactionStatus {
  DRAFT
  WAITING_APPROVAL
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum ReimbursementStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
